#!/usr/bin/env bash
# Pre-commit guard: refuse to commit local-only secret files.
#
# `src/environments/environment.secrets.ts` holds real API keys and is
# gitignored, but a stray `git add -A` or a colleague unfamiliar with the
# repo could still stage it. Abort early so we never push keys to a public
# repo by accident.

set -e

SECRET_FILES=(
  "src/environments/environment.secrets.ts"
)

staged=$(git diff --cached --name-only --diff-filter=AM)

for file in "${SECRET_FILES[@]}"; do
  if echo "$staged" | grep -Fxq "$file"; then
    echo "✖ Refusing to commit secret file: $file"
    echo "  This file is supposed to stay local. Unstage with:"
    echo "    git restore --staged $file"
    exit 1
  fi
done

# Belt-and-suspenders: scan staged diff for raw key patterns. Catches the
# case where someone hardcodes a key into a normal file (e.g. environment.ts).
if git diff --cached -U0 | grep -E '^\+.*(phc_[A-Za-z0-9]{30,}|goog_[A-Za-z0-9]{20,}|sk_(live|test)_[A-Za-z0-9]{20,})' >/dev/null; then
  echo "✖ Possible API key found in staged changes."
  echo "  Move the value to src/environments/environment.secrets.ts and"
  echo "  reference it via environmentSecrets.* instead."
  exit 1
fi
